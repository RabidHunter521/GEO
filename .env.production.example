# ─────────────────────────────────────────────────────────────────────────────
# SeenBy — PRODUCTION env source of truth.  See docs/DEPLOYMENT.md.
#
# This .example file is TRACKED (blank placeholders only — never put real
# secrets here). Your filled-in copy lives in .env.production, which is
# gitignored. Copy it:   cp .env.production.example .env.production
#
# This is NOT loaded by any service directly. It is your single worksheet:
#   - paste the [BACKEND] block into Railway api / worker / beat (all three)
#   - paste the [FRONTEND] block into Vercel
# ─────────────────────────────────────────────────────────────────────────────

# == [BACKEND] Railway: set on api, worker, AND beat ==========================

# Supabase → Settings → Database → Connect → Session pooler (IPv4). Phase 1.1
DATABASE_URL=
# Railway Redis plugin. Phase 2.1
REDIS_URL=

# Production marker — disables the interactive API docs (/docs, /redoc,
# /openapi.json) so the route surface isn't publicly enumerable.
ENVIRONMENT=production

# LLM keys (Phase 1.4). ANTHROPIC is required; others power their platforms.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Resend (Phase 1.3). seenby.my domain must be verified.
RESEND_API_KEY=

# Generated: openssl rand -hex 32  (Phase 1.5). MUST equal the frontend value.
ADMIN_API_KEY=

# Frontend origin (Phase 3). HTTPS, no trailing slash.
ALLOWED_ORIGINS=https://app.seenby.my
FRONTEND_BASE_URL=https://app.seenby.my

# Cloudflare R2 (Phase 1.2)
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=seenby-reports
CLOUDFLARE_R2_PUBLIC_BUCKET_NAME=seenby-public
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.seenby.my

# Required on Railway (app sits behind a proxy). Phase 2.
RATE_LIMIT_TRUSTED_PROXY=1

# Cost guardrails (Phase 1.4). Defaults shown — confirm vs your pricing.
BUDGET_CLIENT_MONTHLY_USD=20
BUDGET_GLOBAL_DAILY_USD=50

# Telegram admin alerts (Phase 1.6). Optional — blank = email-only alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# == [FRONTEND] Vercel =======================================================

NEXTAUTH_URL=https://app.seenby.my
# Generated: openssl rand -hex 32 (Phase 1.5)
AUTH_SECRET=
ADMIN_USERNAME=
# Generated: openssl rand -base64 24 (Phase 1.5)
ADMIN_PASSWORD=
# Railway api public URL (Phase 2)
API_BASE_URL=https://api.seenby.my
# MUST be byte-identical to the backend ADMIN_API_KEY above.
ADMIN_API_KEY=
