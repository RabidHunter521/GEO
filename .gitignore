# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
.venv/

# Secrets — never commit real env files (templates use *.example and are tracked)
.env
.env.*
!.env.example
!.env.*.example

# Node / Frontend
node_modules/
.next/
out/

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Playwright debug artifacts
.playwright-mcp/
frontend/screenshots/

# Graphify output
graphify-out/

# Generated artifacts dropped at repo root (screenshots, PDF exports, browser
# snapshot dumps) — not source, regenerated on demand. Root-only (leading /)
# so this doesn't shadow real assets nested under frontend/backend.
/*.jpeg
/*.jpg
/*.png
/*.pdf
/snap-*.yml
