# Use the Supavisor session pooler (IPv4) — Settings > Database > Connect >
# Session pooler. The direct host ([project].supabase.co) is IPv6-only.
DATABASE_URL=postgresql://postgres.[project]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres
REDIS_URL=redis://localhost:6379/0
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RESEND_API_KEY=your_resend_api_key_here
# Optional: Telegram admin alerts. Leave blank to disable (alerts still email).
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ADMIN_API_KEY=change_me_to_a_random_secret
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000
CLOUDFLARE_R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=seenby-reports
CLOUDFLARE_R2_PUBLIC_URL=https://pub.r2.dev/<bucket_name>
