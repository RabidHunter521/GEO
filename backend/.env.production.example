# Copy to backend/.env.production on the VPS and fill in real values.
# Never commit the real file — .gitignore already excludes .env.production.

# Supabase Session Pooler (port 5432, IPv4) — required for the alembic
# migration that runs on every backend-web boot. Do NOT use the port-6543
# transaction pooler here; it can't run DDL reliably.
DATABASE_URL=postgresql://postgres.[project]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres

# Docker Compose service name, not localhost — resolved via the compose network.
REDIS_URL=redis://redis:6379/0

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RESEND_API_KEY=your_resend_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ADMIN_API_KEY=change_me_to_a_random_secret

# Real domain, https — must match where Caddy terminates TLS.
ALLOWED_ORIGINS=https://your-domain.com
FRONTEND_BASE_URL=https://your-domain.com

CLOUDFLARE_R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=seenby-reports
CLOUDFLARE_R2_PUBLIC_BUCKET_NAME=seenby-public
CLOUDFLARE_R2_PUBLIC_URL=https://pub.r2.dev/<public_bucket_name>
